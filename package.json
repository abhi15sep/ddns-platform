{
  "name": "ddns-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "dashboard",
    "client-app"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "dev:client": "npm run dev --workspace=client-app",
    "dev:db": "docker compose up -d",
    "build:server": "npm run build --workspace=server",
    "build:dashboard": "npm run build --workspace=dashboard",
    "build:client": "npm run build --workspace=client-app",
    "migrate": "cd db && sh migrate.sh",
    "lint": "npm run lint --workspaces --if-present"
  }
}