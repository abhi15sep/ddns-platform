# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (App database)
DATABASE_URL=postgresql://ddnsuser:password@localhost:5432/ddns

# PowerDNS
PDNS_API_URL=http://127.0.0.1:8081/api/v1
PDNS_API_KEY=change-me-to-a-long-random-secret
DDNS_ZONE=dyn.devops-monk.com

# JWT
JWT_SECRET=change-me-to-another-long-random-secret

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# App URL (used for OAuth callbacks)
APP_URL=https://devops-monk.com
API_URL=https://api.devops-monk.com